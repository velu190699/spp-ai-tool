# The main `run`/`report` commands need no credentials — they read from a
# locally-synced SharePoint/OneDrive folder. These are only needed for the RR
# settlement pipeline's `--links` mode (python main.py settlement-report --links ...),
# which downloads RR .docx files directly via Microsoft Graph. Requires an Azure
# app registration with Sites.Read.All (application permission).

# Microsoft Graph auth for src/settlement/pipeline.py --links mode
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
# Declared for future direct drive addressing; not used by the current
# share-link resolution flow (which discovers drive/item IDs from the URL).
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=

# Slack delivery. Two options — you only need ONE:
#  A) Incoming Webhook (posts to the channel the webhook is bound to):
SLACK_WEBHOOK_URL=
#  B) Bot token + channel (uses chat.postMessage; needs the chat:write scope
#     and the bot must be invited to the channel). Takes precedence over the
#     webhook when both are set. Channel can be a name (#market-updates) or ID.
SLACK_BOT_TOKEN=
SLACK_CHANNEL=
