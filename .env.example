# V1 runs without real SharePoint or Slack credentials.
# These are intentionally pending until the integration contract is defined.

# Future SharePoint / Microsoft Graph integration
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=

# Slack delivery. Two options — you only need ONE:
#  A) Incoming Webhook (posts to the channel the webhook is bound to):
SLACK_WEBHOOK_URL=
#  B) Bot token + channel (uses chat.postMessage; needs the chat:write scope
#     and the bot must be invited to the channel). Takes precedence over the
#     webhook when both are set. Channel can be a name (#market-updates) or ID.
SLACK_BOT_TOKEN=
SLACK_CHANNEL=
